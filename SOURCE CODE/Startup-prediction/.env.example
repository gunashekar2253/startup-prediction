# ============================================================
# STARTUP PREDICTOR - Environment Variables
# ============================================================
# 1. Copy this file and rename it to ".env"
# 2. Fill in your actual API keys below
# 3. Never commit the .env file to GitHub (it's in .gitignore)

# --- NewsAPI (Free: 100 requests/day) ---
# Get your free key at: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# --- Clearbit (Free tier available) ---
# Get your free key at: https://dashboard.clearbit.com/signup
# NOTE: Clearbit has been acquired by HubSpot. Free alternative: https://opencorporates.com/
CLEARBIT_API_KEY=your_clearbit_key_here

# --- Flask Secret Key (generate any random string) ---
SECRET_KEY=change_this_to_a_random_secret_string_123

# --- Yahoo Finance (NO KEY NEEDED - it's free/public) ---
# Yahoo Finance API is used without authentication in this project
